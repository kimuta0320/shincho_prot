	var getJSONData = function(path,type){
		var dfd=$.Deferred();
		$.ajax({
			cache:false,
			url:path,
			type:type,
			data:{},
			dataType:"json",
			success:function(data){
				dfd.resolve(data);
			},
			error:function(data){
				dfd.reject(data);
			}
		});
		return dfd.promise();
	}

