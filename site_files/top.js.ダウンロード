				SoundStart();
				document.getElementById('bgm-sound').play();
				$.cookie('shincho-sound', 'sound', { expires: date, path: '/' });
			}
		});
	}


// ----------------------------------------------------------------------------
// More Button Click
// ----------------------------------------------------------------------------
var moreClick = function(){
	var $more = $('.nav-more-01');
	var list1 = [];
	var list2 = [];

	var $listContent = $('[class^="item-"]');
	var currentIndex = 20; // 初期表示件数

	$listContent.each(function() {
			var number = parseInt($(this).attr('class').match(/-([0-9]+)/)[1]);
			var $thisItem = $(this);

			if (number >= 1 && number <= 20) {
					list1.push($thisItem);
					$thisItem.css('display', 'block');
			} else if (number >= 21) {
					list2.push($thisItem);
					$thisItem.css('display', 'none');
			}
	});

	$more.on('click', function() {
		var elemCount = currentIndex + 42;
		$listContent.each(function() {
				var number = parseInt($(this).attr('class').match(/-([0-9]+)/)[1]);
				if (number >= currentIndex && number <= elemCount) {
						$(this).delay((number - currentIndex) * 50).fadeTo(800, 1);
				}
		});
		currentIndex = elemCount;

		if (currentIndex > $listContent.length) {
				$(this).hide();
		}
	});
}



