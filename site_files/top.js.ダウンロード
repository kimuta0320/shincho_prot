var initGacha = function(){
	var $gachaArea = $('.gacha-area');
	if( !$gachaArea.length ){
		return;
	}

	var $gachaButton = $gachaArea.find('.gacha-button');
	var $gachaResultLink = $gachaArea.find('.gacha-result-link');
	var $gachaResultImg = $gachaArea.find('.gacha-result');

	var getItems = function(){
		var items = [];
		$('.list-index-01').find('li a').each(function(){
			var $a = $(this);
			var href = $a.attr('href') || '';
			var src = $a.find('img').attr('src') || '';
			var match = src.match(/\/([0-9]{6})\./) || href.match(/book([0-9]{6})/);

			if( match ){
				var id = match[1];
				items.push({
					id: id,
					src: src,
					href: href || ('/detail/index.html?book' + id)
				});
			}
		});
		return items;
	};

	var setItem = function(item){
		$gachaResultImg.attr('src', item.src);
		$gachaResultLink.attr('href', item.href);
		$gachaResultLink.removeClass('is-disabled').attr('aria-disabled', 'false');
	};

	$gachaResultLink.addClass('is-disabled').attr('aria-disabled', 'true').removeAttr('href');
	$gachaResultLink.on('click', function(e){
		if( $(this).hasClass('is-disabled') ){
			e.preventDefault();
		}
	});

	var rolling = false;
	var intervalId = null;

	$gachaButton.on('click', function(){
		if( rolling ){
			return;
		}

		var items = getItems();
		if( !items.length ){
			return;
		}

		rolling = true;
		var elapsed = 0;
		var step = 50;
		var total = 3000;

		intervalId = setInterval(function(){
			var item = items[Math.floor(Math.random() * items.length)];
			setItem(item);
			elapsed += step;
			if( elapsed >= total ){
				clearInterval(intervalId);
				intervalId = null;
				rolling = false;
			}
		}, step);
	});
}

initGacha();


